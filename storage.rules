rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Specific rules for the orders path
    // Specific rules for the orders path
    match /orders/{userId}/{orderId}/{allPaths=**} {
      // Allow students to upload files only to their own order folder
      allow write: if request.auth != null && request.auth.uid == userId;

      // PREVENT PRIVACY LEAK (Bug 6): Only allow the student, the specific shopkeeper, or admin to read
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.type == 'ADMIN' ||
        firestore.get(/databases/(default)/documents/orders/$(orderId)).data.shopId == firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.shopId
      );
    }

    // Specific rules for support tickets path
    match /tickets/{ticketId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type == 'ADMIN';
    }

    // Users can read and write their own profile
    // Admin can read/write any user profile (for account conversion)
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Shops
    match /shops/{shopId} {
      // Anyone can read shop listings (e.g., for students to browse)
      allow read: if true;

      // Authenticated users who are shop owners can create their shop
      // Ensure the ownerUserId in the new shop document matches the authenticated user
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerUserId;

      // Only the owner of the shop (or admin) can update it
      // PRICING VALIDATION: bwPerPage and colorPerPage must be >= 0 to prevent
      // negative pricing attacks that could crash Razorpay or create free orders
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.ownerUserId || isAdmin()) &&
        request.resource.data.customPricing.bwPerPage >= 0 &&
        request.resource.data.customPricing.colorPerPage >= 0;

      // Only the owner or admin can delete
      allow delete: if request.auth != null && (request.auth.uid == resource.data.ownerUserId || isAdmin());
    }

    // Orders
    match /orders/{orderId} {
      // Students can create their own orders
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;

      // Students can read/update their own orders
      // Shop owners can read/update orders for their shop
      // Admin can read/update any order
      allow read, update: if request.auth != null && 
                          (request.auth.uid == resource.data.userId || 
                           resource.data.shopId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId ||
                           isAdmin());
      
      // Deletion of orders might be restricted or handled by functions
      allow delete: if false;
    }

    // Payouts — admin has full access, shop owners can create requests and manage their own
    match /payouts/{payoutId} {
      // Admin can do anything with payouts
      allow read, write: if request.auth != null && isAdmin();
      
      // Shop owners can CREATE payout requests for their own shop
      allow create: if request.auth != null && 
                    request.resource.data.shopId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId;

      // Shop owners can read payouts for their shop
      allow read: if request.auth != null && 
                  resource.data.shopId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId;

      // Shop owners can update status on their own payouts (confirm/dispute)
      allow update: if request.auth != null && 
                    resource.data.shopId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId;
    }

    // Notifications — Firestore-backed cross-user notification system
    match /notifications/{notificationId} {
      // Users can read their own notifications (filtered by recipientUserId)
      allow read: if request.auth != null && resource.data.recipientUserId == request.auth.uid;

      // Any authenticated user can create notifications (for cross-user communication)
      allow create: if request.auth != null;

      // Users can update their own notifications (e.g., mark as read)
      allow update: if request.auth != null && resource.data.recipientUserId == request.auth.uid;

      // Only admin or backend Cloud Functions can delete notifications
      allow delete: if isAdmin();
    }
  }
}
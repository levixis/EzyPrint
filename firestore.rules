rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shops
    match /shops/{shopId} {
      // Anyone can read shop listings (e.g., for students to browse)
      allow read: if true;

      // Authenticated users who are shop owners can create their shop
      // Ensure the ownerUserId in the new shop document matches the authenticated user
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerUserId;

      // Only the owner of the shop can update or delete it
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUserId;
    }

    // Orders
    match /orders/{orderId} {
      // Students can create their own orders
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;

      // Students can read/update their own orders
      // Shop owners can read/update orders for their shop
      allow read, update: if request.auth != null && 
                          (request.auth.uid == resource.data.userId || 
                           (get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerUserId == request.auth.uid));
      
      // Deletion of orders might be restricted or handled by functions
      allow delete: if false; // Example: prevent client-side deletion
    }
  }
}